// Franchise Draft Platform: Prisma schema (PostgreSQL / Supabase)

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OWNER
  VIEWER
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

/// How players are allocated to teams before the tournament runs.
enum AllocationMethod {
  SNAKE_DRAFT
  RANDOM_ASSIGNMENT
  LIVE_AUCTION
}

enum AuctionLotStatus {
  OPEN
  SOLD
  UNSOLD
  CANCELLED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum DraftPhase {
  SETUP
  READY
  LIVE
  PAUSED
  FROZEN
  LOCKED
  COMPLETED
}

enum PickStatus {
  PENDING_CONFIRMATION
  CONFIRMED
}

enum DraftLogAction {
  DRAFT_STARTED
  DRAFT_PAUSED
  DRAFT_RESUMED
  DRAFT_ENDED
  DRAFT_FROZEN
  DRAFT_UNLOCKED
  DRAFT_LOCKED
  TURN_ADVANCED
  TURN_REVERTED
  TURN_SKIPPED
  ORDER_RANDOMIZED
  PICK_REQUESTED
  PICK_CONFIRMED
  PICK_UNDONE
  PICK_REMOVED
  PLAYER_ASSIGNED
  PLAYER_UNAVAILABLE
  PLAYER_LOCKED
  SYNC_FORCED
  OVERRIDE_VALIDATION
  ERROR
  AUCTION_FOCUS_CATEGORY
  LOT_OPENED
  BID_PLACED
  LOT_SOLD
  LOT_UNSOLD
  LOT_CANCELLED
  RANDOM_ASSIGNMENT_RUN
}

/// Racquet sports the platform supports. Match model (singles/doubles + score
/// per side) is shared across all of them; sport drives terminology and defaults.
enum Sport {
  BADMINTON
  PICKLEBALL
  TENNIS
  TABLE_TENNIS
  SQUASH
  PADEL
  OTHER
}

enum TournamentFormat {
  DOUBLES_ONLY
  MIXED
  SINGLES_ONLY
}

enum FixtureMatchType {
  SINGLES
  DOUBLES
}

enum FixtureStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum FixtureSide {
  SIDE_ONE
  SIDE_TWO
}

model UserProfile {
  id           String    @id @db.Uuid
  email        String    @unique
  displayName  String?
  role         UserRole  @default(VIEWER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  tournamentsCreated Tournament[] @relation("TournamentCreator")
  teamsOwned         Team[]       @relation("TeamOwner")
  draftLogs          DraftLog[]
  picksConfirmed     Pick[]       @relation("PickConfirmer")
  ownerStubPlayers   Player[]     @relation("OwnerPlayerStub")
  auctionBidsPlaced  AuctionBid[] @relation("AuctionBidder")
  organizationMemberships OrganizationMembership[]
}

/// SaaS tenant: a league operator that owns tournaments. Legacy tournaments
/// keep organizationId null and stay visible to their creator only.
model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships OrganizationMembership[]
  tournaments Tournament[]
  leagues     League[]
}

/// A recurring, branded competition that groups tournaments/seasons under one
/// banner (e.g. "Indiranagar Smashers League" → Summer Cup, Winter Cup…). Has
/// its own public page. Tournaments optionally belong to a league.
model League {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @db.Uuid
  name           String
  slug           String    @unique
  description    String?
  logoUrl        String?
  colorHex       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tournaments  Tournament[]

  @@index([organizationId])
}

model OrganizationMembership {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userId         String   @db.Uuid
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         UserProfile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
}

model Tournament {
  id                     String      @id @default(uuid()) @db.Uuid
  name                   String
  slug                   String      @unique
  description            String?
  sport                  Sport            @default(BADMINTON)
  format                 TournamentFormat @default(DOUBLES_ONLY)
  logoUrl                String?
  colorHex               String?
  createdById            String      @db.Uuid
  organizationId         String?     @db.Uuid
  leagueId               String?     @db.Uuid
  /// Free-text season label within a league, e.g. "Summer 2026". Optional.
  season                 String?
  allocationMethod       AllocationMethod @default(SNAKE_DRAFT)
  /// Auction economy in whole points (only meaningful when allocationMethod is LIVE_AUCTION).
  auctionPurse           Int         @default(10000)
  auctionMinIncrement    Int         @default(100)
  auctionDefaultBasePrice Int        @default(100)
  draftPhase             DraftPhase  @default(SETUP)
  picksPerTeam           Int         @default(10)
  currentSlotIndex       Int         @default(0)
  draftOrderLocked       Boolean     @default(false)
  pendingPickPlayerId    String?     @unique @db.Uuid
  pendingPickTeamId      String?     @unique @db.Uuid
  pendingIdempotencyKey  String?
  overrideValidation     Boolean     @default(false)
  pickTimerSeconds       Int?
  draftStartedAt           DateTime?
  draftEndedAt             DateTime?
  playerEntryFeeMinorUnits Int?
  playerEntryFeeCurrencyCode String   @default("INR") @db.VarChar(3)
  /// When LIVE, owners see only nominees from this roster group; null means all groups (legacy / open drafting).
  activeAuctionRosterCategoryId String?    @db.Uuid
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  deletedAt                DateTime?

  creator           UserProfile      @relation("TournamentCreator", fields: [createdById], references: [id])
  organization      Organization?    @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  league            League?          @relation(fields: [leagueId], references: [id], onDelete: SetNull)
  auctionLots       AuctionLot[]
  teams             Team[]
  players           Player[]
  rosterCategories RosterCategory[]
  activeAuctionRosterCategory RosterCategory? @relation("ActiveAuctionSpotlightCategory", fields: [activeAuctionRosterCategoryId], references: [id], onDelete: SetNull)
  squadRules    SquadRule[]
  draftSlots    DraftOrderSlot[]
  picks         Pick[]
  draftLogs     DraftLog[]
  fixtureTies   FixtureTie[]
  fixtureMatches FixtureMatch[]
  pendingPlayer Player?           @relation("PendingPlayer", fields: [pendingPickPlayerId], references: [id])
  pendingTeam   Team?             @relation("PendingTeam", fields: [pendingPickTeamId], references: [id])

  @@index([createdById])
  @@index([organizationId])
  @@index([leagueId])
  @@index([draftPhase])
}

model RosterCategory {
  id           String    @id @default(uuid()) @db.Uuid
  tournamentId String    @db.Uuid
  name         String
  displayOrder Int       @default(0)
  colorHex     String?
  archivedAt   DateTime?
  /// Optional stable bucket for automation (e.g. owner stub sync). Commissioner-created categories stay null.
  stableKey    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  players    Player[]
  squadRules SquadRule[]
  tournamentsAuctionSpotlight Tournament[] @relation("ActiveAuctionSpotlightCategory")

  @@index([tournamentId])
  @@unique([tournamentId, stableKey])
}

model Team {
  id             String    @id @default(uuid()) @db.Uuid
  tournamentId   String    @db.Uuid
  name           String
  shortName      String?
  logoUrl        String?
  colorHex       String?
  ownerUserId    String?   @db.Uuid
  displayOrder   Int       @default(0)
  isEliminated   Boolean   @default(false)
  /// Per-team auction purse override in points; null falls back to Tournament.auctionPurse.
  purseOverride  Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  tournament      Tournament       @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  owner           UserProfile?     @relation("TeamOwner", fields: [ownerUserId], references: [id])
  draftSlots           DraftOrderSlot[]
  picks                Pick[]
  pendingPickFor       Tournament? @relation("PendingTeam")
  fixtureTiesAsTeamOne FixtureTie[] @relation("FixtureTieTeamOne")
  fixtureTiesAsTeamTwo FixtureTie[] @relation("FixtureTieTeamTwo")
  fixtureParticipants  FixtureMatchParticipant[]
  auctionLotsLeading   AuctionLot[] @relation("LotCurrentBidTeam")
  auctionLotsWon       AuctionLot[] @relation("LotWinningTeam")
  auctionBids          AuctionBid[]

  @@index([tournamentId])
  @@index([ownerUserId])
}

model Player {
  id               String       @id @default(uuid()) @db.Uuid
  tournamentId     String       @db.Uuid
  name             String
  photoUrl         String?
  rosterCategoryId String       @db.Uuid
  gender           Gender
  notes            String?
  hasPaidEntryFee  Boolean      @default(false)
  /// Auction base price in points; null falls back to Tournament.auctionDefaultBasePrice.
  basePrice        Int?
  isUnavailable    Boolean      @default(false)
  isLocked         Boolean      @default(false)
  isEliminated     Boolean      @default(false)
  linkedOwnerUserId String?     @db.Uuid
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?

  tournament    Tournament      @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rosterCategory RosterCategory @relation(fields: [rosterCategoryId], references: [id], onDelete: Restrict)
  linkedOwner    UserProfile?    @relation("OwnerPlayerStub", fields: [linkedOwnerUserId], references: [id])
  picks          Pick[]
  pendingPickFor  Tournament?     @relation("PendingPlayer")
  fixtureParticipants FixtureMatchParticipant[]
  auctionLots     AuctionLot[]

  @@unique([tournamentId, linkedOwnerUserId])
  @@index([tournamentId])
  @@index([rosterCategoryId])
  @@index([name])
}

model SquadRule {
  id               String       @id @default(uuid()) @db.Uuid
  tournamentId     String       @db.Uuid
  rosterCategoryId String       @db.Uuid
  maxCount         Int
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tournament     Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  rosterCategory RosterCategory @relation(fields: [rosterCategoryId], references: [id], onDelete: Restrict)

  @@unique([tournamentId, rosterCategoryId])
  @@index([tournamentId])
}

model DraftOrderSlot {
  id           String   @id @default(uuid()) @db.Uuid
  tournamentId String   @db.Uuid
  slotIndex    Int
  teamId       String   @db.Uuid
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, slotIndex])
  @@index([tournamentId])
  @@index([teamId])
}

model Pick {
  id               String       @id @default(uuid()) @db.Uuid
  tournamentId     String       @db.Uuid
  playerId         String       @db.Uuid
  teamId           String       @db.Uuid
  slotIndex        Int
  status           PickStatus   @default(CONFIRMED)
  /// Sold price in points for LIVE_AUCTION picks; null for drafted/assigned picks.
  price            Int?
  idempotencyKey   String?      @unique
  confirmedByUserId String?     @db.Uuid
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  confirmedBy UserProfile? @relation("PickConfirmer", fields: [confirmedByUserId], references: [id])

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player     Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team       Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, playerId])
  @@index([tournamentId])
  @@index([teamId])
  @@index([slotIndex])
}

/// One auction "lot" = one player put up for bidding. Re-auctioning an UNSOLD
/// player creates a fresh lot, so (tournamentId, playerId) is intentionally
/// not unique. A partial unique index (added in raw migration SQL) guarantees
/// at most one OPEN lot per tournament.
model AuctionLot {
  id               String           @id @default(uuid()) @db.Uuid
  tournamentId     String           @db.Uuid
  playerId         String           @db.Uuid
  status           AuctionLotStatus @default(OPEN)
  basePrice        Int
  currentBid       Int?
  currentBidTeamId String?          @db.Uuid
  /// Optimistic-concurrency version: a bid only lands if it names the bidCount it saw.
  bidCount         Int              @default(0)
  finalPrice       Int?
  winningTeamId    String?          @db.Uuid
  openedByUserId   String?          @db.Uuid
  closedAt         DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  tournament     Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  player         Player     @relation(fields: [playerId], references: [id], onDelete: Cascade)
  currentBidTeam Team?      @relation("LotCurrentBidTeam", fields: [currentBidTeamId], references: [id], onDelete: SetNull)
  winningTeam    Team?      @relation("LotWinningTeam", fields: [winningTeamId], references: [id], onDelete: SetNull)
  bids           AuctionBid[]

  @@index([tournamentId, status])
  @@index([tournamentId, createdAt])
  @@index([playerId])
}

model AuctionBid {
  id           String   @id @default(uuid()) @db.Uuid
  lotId        String   @db.Uuid
  teamId       String   @db.Uuid
  amount       Int
  bidderUserId String?  @db.Uuid
  createdAt    DateTime @default(now())

  lot    AuctionLot   @relation(fields: [lotId], references: [id], onDelete: Cascade)
  team   Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  bidder UserProfile? @relation("AuctionBidder", fields: [bidderUserId], references: [id])

  @@index([lotId, createdAt])
  @@index([teamId])
}

model DraftLog {
  id            String         @id @default(uuid()) @db.Uuid
  tournamentId  String         @db.Uuid
  action        DraftLogAction
  message       String?
  payload       Json?
  actorUserId   String?        @db.Uuid
  createdAt     DateTime       @default(now())

  tournament Tournament   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  actor      UserProfile? @relation(fields: [actorUserId], references: [id])

  @@index([tournamentId, createdAt])
}

model FixtureTie {
  id            String   @id @default(uuid()) @db.Uuid
  tournamentId  String   @db.Uuid
  categoryLabel String?
  roundNumber   Int?
  sequence      Int      @default(0)
  teamOneId     String   @db.Uuid
  teamTwoId     String   @db.Uuid
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  teamOne    Team       @relation("FixtureTieTeamOne", fields: [teamOneId], references: [id], onDelete: Cascade)
  teamTwo    Team       @relation("FixtureTieTeamTwo", fields: [teamTwoId], references: [id], onDelete: Cascade)
  matches    FixtureMatch[]

  @@index([tournamentId, sequence])
}

model FixtureMatch {
  id            String          @id @default(uuid()) @db.Uuid
  tournamentId  String          @db.Uuid
  tieId         String?         @db.Uuid
  categoryLabel String?
  matchType     FixtureMatchType
  sequence      Int             @default(0)
  status        FixtureStatus   @default(SCHEDULED)
  sideOneScore  Int?
  sideTwoScore  Int?
  winnerSide    FixtureSide?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  tie        FixtureTie? @relation(fields: [tieId], references: [id], onDelete: Cascade)
  participants FixtureMatchParticipant[]

  @@index([tournamentId, sequence])
  @@index([tieId, sequence])
}

model FixtureMatchParticipant {
  id        String      @id @default(uuid()) @db.Uuid
  matchId   String      @db.Uuid
  playerId  String      @db.Uuid
  side      FixtureSide
  teamId    String?     @db.Uuid
  createdAt DateTime    @default(now())

  match  FixtureMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player       @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team   Team?        @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([matchId, side])
  @@index([playerId])
  @@index([teamId])
}
